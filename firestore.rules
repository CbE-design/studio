/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. All data is nested under
 * /users/{userId}, and only the authenticated user can read or write their own data.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profiles. Only the user can read/write their profile.
 * - /users/{userId}/bankAccounts/{bankAccountId}: Stores bank accounts. Only the user can manage their bank accounts.
 * - /users/{userId}/bankAccounts/{bankAccountId}/transactions/{transactionId}: Stores transactions. Only the user can access their transaction history.
 * - /users/{userId}/beneficiaries/{beneficiaryId}: Stores beneficiaries. Only the user can manage their beneficiaries.
 * - /users/{userId}/scheduledPayments/{scheduledPaymentId}: Stores scheduled payments. Only the user can manage their scheduled payments.
 * - /users/{userId}/financialTips/{financialTipId}: Stores financial tips. Only the user can access their financial tips.
 * - /atms/{atmId}: Stores ATM locations. This collection is publicly readable.
 * - /categories/{categoryId}: Stores transaction categories. This collection is publicly readable.
 *
 * Key Security Decisions:
 * - User listing is disallowed.
 * - ATMs and Categories are publicly readable.
 * - All other collections enforce strict user ownership.
 *
 * Denormalization for Authorization:
 * - The `userId` field is duplicated within the `BankAccount`, `Beneficiary`, `ScheduledPayment` and `FinancialTip` documents. This denormalization enables direct access to these documents based on the `userId` without requiring additional `get()` calls, improving rule efficiency and preventing excessive reads.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces user-level access control for user profiles. Only the authenticated user can read or write their own profile.
     * @path /users/{userId}
     * @allow (create) - Authenticated user with matching user ID can create their profile.
     * @allow (get, list, update, delete) - Authenticated user with matching user ID can read or modify their profile.
     * @deny (create) - Authenticated user with non-matching user ID cannot create a profile.
     * @deny (get, list, update, delete) - Authenticated user with non-matching user ID cannot read or modify another user's profile.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && resource.data.id == userId;
      allow delete: if isOwner(userId) && resource.data.id == userId;
    }

    /**
     * @description Enforces user-level access control for bank accounts. Only the authenticated user can manage their bank accounts.
     * @path /users/{userId}/bankAccounts/{bankAccountId}
     * @allow (create) - Authenticated user with matching user ID can create a bank account.
     * @allow (get, list, update, delete) - Authenticated user with matching user ID can read or modify their bank accounts.
     * @deny (create) - Authenticated user with non-matching user ID cannot create a bank account.
     * @deny (get, list, update, delete) - Authenticated user with non-matching user ID cannot read or modify another user's bank accounts.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/bankAccounts/{bankAccountId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isOwner(userId) && resource.data.userId == userId;
      allow delete: if isOwner(userId) && resource.data.userId == userId;
    }

    /**
     * @description Enforces user-level access control for transactions. Only the authenticated user can access their transaction history.
     * @path /users/{userId}/bankAccounts/{bankAccountId}/transactions/{transactionId}
     * @allow (create) - Authenticated user with matching user ID can create a transaction.
     * @allow (get, list, update, delete) - Authenticated user with matching user ID can read or modify their transaction history.
     * @deny (create) - Authenticated user with non-matching user ID cannot create a transaction.
     * @deny (get, list, update, delete) - Authenticated user with non-matching user ID cannot read or modify another user's transaction history.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/bankAccounts/{bankAccountId}/transactions/{transactionId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Enforces user-level access control for beneficiaries. Only the authenticated user can manage their beneficiaries.
     * @path /users/{userId}/beneficiaries/{beneficiaryId}
     * @allow (create) - Authenticated user with matching user ID can create a beneficiary.
     * @allow (get, list, update, delete) - Authenticated user with matching user ID can read or modify their beneficiaries.
     * @deny (create) - Authenticated user with non-matching user ID cannot create a beneficiary.
     * @deny (get, list, update, delete) - Authenticated user with non-matching user ID cannot read or modify another user's beneficiaries.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/beneficiaries/{beneficiaryId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isOwner(userId) && resource.data.userId == userId;
      allow delete: if isOwner(userId) && resource.data.userId == userId;
    }

    /**
     * @description Enforces user-level access control for scheduled payments. Only the authenticated user can manage their scheduled payments.
     * @path /users/{userId}/scheduledPayments/{scheduledPaymentId}
     * @allow (create) - Authenticated user with matching user ID can create a scheduled payment.
     * @allow (get, list, update, delete) - Authenticated user with matching user ID can read or modify their scheduled payments.
     * @deny (create) - Authenticated user with non-matching user ID cannot create a scheduled payment.
     * @deny (get, list, update, delete) - Authenticated user with non-matching user ID cannot read or modify another user's scheduled payments.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/scheduledPayments/{scheduledPaymentId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isOwner(userId) && resource.data.userId == userId;
      allow delete: if isOwner(userId) && resource.data.userId == userId;
    }

    /**
     * @description Enforces user-level access control for financial tips. Only the authenticated user can access their financial tips.
     * @path /users/{userId}/financialTips/{financialTipId}
     * @allow (create) - Authenticated user with matching user ID can create a financial tip.
     * @allow (get, list, update, delete) - Authenticated user with matching user ID can read or modify their financial tips.
     * @deny (create) - Authenticated user with non-matching user ID cannot create a financial tip.
     * @deny (get, list, update, delete) - Authenticated user with non-matching user ID cannot read or modify another user's financial tips.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId}/financialTips/{financialTipId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isOwner(userId) && resource.data.userId == userId;
      allow delete: if isOwner(userId) && resource.data.userId == userId;
    }

    /**
     * @description Allows public read access to ATM locations. No write access is allowed.
     * @path /atms/{atmId}
     * @allow (get, list) - Any user (authenticated or not) can read ATM locations.
     * @deny (create, update, delete) - No user can create, update, or delete ATM locations.
     * @principle Allows public read access for a global resource.
     */
    match /atms/{atmId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Allows public read access to transaction categories. No write access is allowed.
     * @path /categories/{categoryId}
     * @allow (get, list) - Any user (authenticated or not) can read transaction categories.
     * @deny (create, update, delete) - No user can create, update, or delete transaction categories.
     * @principle Allows public read access for a global resource.
     */
    match /categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }
  }
}