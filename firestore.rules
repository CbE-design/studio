rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // The `artifacts` collection is a root collection specific to this app's setup.
    // All user-specific data is stored under a path structure that includes the user's UID.
    match /artifacts/van-schalkwyk-trust-mobile/users/{userId}/{document=**} {
      // Allow read and write access only if the requesting user's UID matches the {userId}
      // in the document path. This is the core security rule that ensures users can only
      // access their own data.
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
